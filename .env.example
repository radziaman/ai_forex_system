# RTS AI Forex System — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env to git.

# === cTrader Open API Credentials (REQUIRED) ===
# Get these from cTrader: Settings → Open API → Create Application
CTRADER_APP_CLIENT_ID=YOUR_APP_CLIENT_ID
CTRADER_APP_CLIENT_SECRET=YOUR_APP_CLIENT_SECRET
CTRADER_APP_ID=YOUR_APP_ID
CTRADER_APP_SECRET=YOUR_APP_SECRET

# cTrader Account (numeric ID from platform)
CTRADER_ACCOUNT_ID=YOUR_ACCOUNT_ID
CTRADER_ACCESS_TOKEN=YOUR_ACCESS_TOKEN
CTRADER_REFRESH_TOKEN=YOUR_REFRESH_TOKEN
CTRADER_DEMO=true

# cTrader FIX API (optional, for FIX connectivity)
CTRADER_FIX_HOST=YOUR_FIX_HOST
CTRADER_FIX_ACCOUNT_ID=YOUR_FIX_ACCOUNT_ID
CTRADER_FIX_SENDER_COMP_ID=YOUR_FIX_SENDER_COMP_ID
CTRADER_FIX_PASSWORD=YOUR_FIX_PASSWORD

# === Provider ===
# Options: ctrader (default), dukascopy
TRADING_PROVIDER=ctrader

# === Redis (optional, for caching/state) ===
REDIS_URL=redis://localhost:6379/0

# === Telegram Alerts (optional) ===
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# === Dashboard ===
DASHBOARD_PORT=8000
DASHBOARD_USER=admin
DASHBOARD_PASS=your_secure_password
LOG_LEVEL=INFO

# === HuggingFace (optional, for model hub) ===
HF_TOKEN=your_hf_token

# === Social Media / Alternative Data (optional) ===
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# === External APIs (optional) ===
NASA_API_KEY=your_nasa_api_key
FRED_API_KEY=your_fred_api_key
