# RTS AI Forex System — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env to git.

# === cTrader Open API Credentials (REQUIRED) ===
# Get these from cTrader: Settings → Open API → Create Application
CTRADER_APP_CLIENT_ID=YOUR_APP_CLIENT_ID
CTRADER_APP_CLIENT_SECRET=YOUR_APP_CLIENT_SECRET

# cTrader Account (numeric ID from platform)
CTRADER_ACCOUNT_ID=YOUR_ACCOUNT_ID

# === Provider ===
# Options: ctrader (default), dukascopy
TRADING_PROVIDER=ctrader

# === Telegram Alerts (optional) ===
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# === Dashboard ===
DASHBOARD_PORT=8000
DASHBOARD_USER=admin
DASHBOARD_PASS=your_secure_password
LOG_LEVEL=INFO
